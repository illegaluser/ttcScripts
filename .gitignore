# Python 바이트코드
__pycache__/
*.pyc

# Claude Code 로컬 IDE 상태 (세션별 permission allowlist / 전역 훅 설정 — 공유 대상 아님)
.claude/

# e2e-pipeline 사용자 비밀번호/계정 — 절대 git 에 올리지 말 것
e2e-pipeline/.env
e2e-pipeline/.dify-cookies.txt
e2e-pipeline/setup.log
e2e-pipeline/jenkins-init/*
!e2e-pipeline/jenkins-init/*.groovy
e2e-pipeline/docker-compose.override.yaml

# Jenkins 에이전트 바이너리 (런타임에 다운로드)
e2e-pipeline/agent.jar
e2e-pipeline/*.jar
.DS_Store

# All-in-One 빌드 산출물 (크고 재생성 가능 — 수GB)
e2e-pipeline/dscore.ttc.playwright-*.tar.gz
# playwright-allinone 이미지의 build.sh 가 빌드 시 채우는 중간 산출물
e2e-pipeline/offline/playwright-allinone/.plugins.txt
e2e-pipeline/offline/playwright-allinone/jenkins-plugin-manager.jar
e2e-pipeline/offline/playwright-allinone/jenkins-plugins/
e2e-pipeline/offline/playwright-allinone/dify-plugins/
# code-AI-quality-allinone 도 동일 패턴 (해당 이미지의 빌드 스크립트 도입 시)
e2e-pipeline/offline/code-AI-quality-allinone/.plugins.txt
e2e-pipeline/offline/code-AI-quality-allinone/jenkins-plugin-manager.jar
e2e-pipeline/offline/code-AI-quality-allinone/jenkins-plugins/
e2e-pipeline/offline/code-AI-quality-allinone/dify-plugins/
e2e-pipeline/offline/code-AI-quality-allinone/offline-assets/
e2e-pipeline/offline/playwright-allinone/offline-assets/
