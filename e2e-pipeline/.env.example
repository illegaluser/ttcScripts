# =============================================================================
# DSCORE Zero-Touch QA — 환경변수 템플릿
#
# 사용법:
#   1. 이 파일을 .env 로 복사:    cp .env.example .env
#   2. 아래 값을 실제로 쓸 값으로 수정 (특히 비밀번호)
#   3. ./setup.sh 실행 — setup.sh 가 .env 를 자동으로 읽는다
#
# 주의:
#   - .env 는 .gitignore 에 등록되어 있어 git 에 올라가지 않는다.
#   - 한 번 setup.sh 를 돌린 뒤 .env 를 바꿔도 계정 정보는 자동으로
#     변경되지 않는다 (Postgres / jenkins_home 볼륨에 저장되어 있음).
#     계정 정보를 바꾸려면 docker compose down -v 후 .env 수정 후 재실행.
#   - 비밀번호는 영문 + 숫자 + 특수문자 8자 이상 권장 (Dify 강제, Jenkins 권장).
# =============================================================================

# ─── Dify 관리자 계정 ────────────────────────────────────────────────────────
# setup.sh Phase 4-1 이 이 값으로 Dify 관리자 계정을 만든다.
# 이후 http://localhost:18081/signin 에서 이 값으로 로그인.
DIFY_EMAIL=admin@example.com
DIFY_PASSWORD=Admin1234!

# ─── Jenkins 관리자 계정 ─────────────────────────────────────────────────────
# Phase 1 의 Groovy init 이 이 값으로 Jenkins 관리자 계정을 만든다.
# 이후 http://localhost:18080/login 에서 이 값으로 로그인.
JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PW=Admin1234!

# ─── Ollama 모드 / 모델 ──────────────────────────────────────────────────────
# OLLAMA_PROFILE=host       → 호스트에 설치된 ollama 사용 (기본)
# OLLAMA_PROFILE=container  → docker compose --profile container-ollama 로 컨테이너 ollama 사용
OLLAMA_PROFILE=host
# Phase 3 에서 확인/Pull 할 모델명. dify-chatflow.yaml 에 하드코딩된 값과 일치 필수.
OLLAMA_MODEL=gemma4:e2b

# ─── Playwright 봇 패턴 회피 ─────────────────────────────────────────────────
# SLOW_MO              : Playwright 액션(click/fill/press) 전 지연(ms). 한 글자 입력 속도에도 영향.
# STEP_INTERVAL_MIN_MS : DSL 스텝 사이 추가 random sleep 의 최소값(ms).
# STEP_INTERVAL_MAX_MS : DSL 스텝 사이 추가 random sleep 의 최대값(ms).
#                        둘 다 0 이면 jitter 비활성화 (테스트/디버그용).
# 권장: reCAPTCHA 등이 자주 뜨면 SLOW_MO 와 STEP_INTERVAL_MAX_MS 를 더 크게.
# SLOW_MO=800
# STEP_INTERVAL_MIN_MS=800
# STEP_INTERVAL_MAX_MS=1500

# ─── 자가 치유 ───────────────────────────────────────────────────────────────
# HEAL_TIMEOUT_SEC     : Dify LLM 치유 호출 단일 timeout(초). 재시도 없음.
#                        모델 추론이 느린 환경에서 8분짜리 heal 을 차단.
# HEAL_TIMEOUT_SEC=60

# ─── 기타 ───────────────────────────────────────────────────────────────────
# mac-ui-tester 노드의 SCRIPTS_HOME 환경변수 값. 비워두면 setup.sh 가 자동 결정.
# SCRIPTS_HOME=

# 로그 파일 경로. 비워두면 e2e-pipeline/setup.log 사용.
# SETUP_LOG=

# DEBUG=1 로 설정 시 curl 요청/응답 등 상세 출력
# DEBUG=0
